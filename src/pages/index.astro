---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main class="page">
    <header class="hero">
      <h1 class="hero-header">It's all going to be ok.</h1>
      <p class="hero-sub">Here's the evidence.</p>
    </header>

    <section class="stats" aria-label="Your wins">
      <div class="stat-card stat-card--scoreboard">
        <span class="stat-label">You vs ADHD</span>
        <span class="stat-value stat-value--score" id="rival-record">&mdash;</span>
      </div>

      <div class="stat-card">
        <span class="stat-value" id="tasks-completed">&mdash;</span>
        <span class="stat-label">Battles won</span>
      </div>
      <div class="stat-card">
        <span class="stat-value" id="things-shipped">&mdash;</span>
        <span class="stat-label">Things shipped</span>
      </div>

      <div class="stat-card stat-card--streak">
        <div class="streak-row">
          <div class="streak-col">
            <span class="stat-value" id="best-streak">&mdash;</span>
            <span class="stat-label">Best streak</span>
          </div>
          <div class="streak-divider" aria-hidden="true"></div>
          <div class="streak-col">
            <span class="stat-value" id="current-streak">&mdash;</span>
            <span class="stat-label">Current streak</span>
          </div>
        </div>
        <div class="streak-viz" id="streak-dots" aria-hidden="true"></div>
      </div>
    </section>

    <section class="highlights" aria-label="Journal highlights"
             id="highlights-section" hidden>
      <h2 class="section-heading">Field report</h2>
      <div id="journal-highlight" class="highlight-card"></div>
    </section>
  </main>
</BaseLayout>

<script>
  import { fetchAchievements } from '../lib/supabase';

  const ZERO_STATE: Record<string, string> = {
    'tasks-completed': 'Ready when you are',
    'things-shipped': 'Something is brewing',
    'best-streak': 'Day one is a streak',
    'current-streak': 'Right now counts',
  };

  function renderStat(el: HTMLElement | null, value: number, id: string) {
    if (!el) return;
    if (value === 0 && ZERO_STATE[id]) {
      el.textContent = ZERO_STATE[id];
      el.classList.add('stat-value--zero');
    } else {
      el.textContent = String(value);
      el.classList.remove('stat-value--zero');
    }
  }

  function renderStreakDots(container: HTMLElement | null, count: number) {
    if (!container) return;
    container.replaceChildren();
    if (count <= 0) return;
    const display = Math.min(count, 14);
    for (let i = 0; i < display; i++) {
      const dot = document.createElement('span');
      dot.className = 'streak-dot';
      dot.setAttribute('aria-hidden', 'true');
      container.appendChild(dot);
    }
    if (count > 14) {
      const more = document.createElement('span');
      more.className = 'streak-more';
      more.textContent = `+${count - 14}`;
      container.appendChild(more);
    }
  }

  async function loadData() {
    const data = await fetchAchievements();

    renderStat(document.getElementById('tasks-completed'), data.lifetimeTasksCompleted, 'tasks-completed');
    renderStat(document.getElementById('things-shipped'), data.thingsShipped, 'things-shipped');
    renderStat(document.getElementById('best-streak'), data.bestStreak, 'best-streak');
    renderStat(document.getElementById('current-streak'), data.currentStreak, 'current-streak');

    const rivalEl = document.getElementById('rival-record');
    if (rivalEl) {
      const { userWins, adhdWins } = data.rivalRecord;
      if (userWins === 0 && adhdWins === 0) {
        rivalEl.textContent = 'Game on';
        rivalEl.classList.add('stat-value--zero');
      } else {
        rivalEl.textContent = `${userWins}\u2013${adhdWins}`;
        rivalEl.classList.remove('stat-value--zero');
      }
    }

    renderStreakDots(document.getElementById('streak-dots'), data.currentStreak);

    const highlightsSection = document.getElementById('highlights-section');
    const highlightEl = document.getElementById('journal-highlight');
    if (highlightsSection && highlightEl && data.journalHighlights.length > 0) {
      highlightsSection.hidden = false;
      const idx = Math.floor(Math.random() * data.journalHighlights.length);
      const h = data.journalHighlights[idx];
      const blockquote = document.createElement('blockquote');
      blockquote.className = 'journal-quote';
      const p = document.createElement('p');
      p.textContent = h.quote;
      const cite = document.createElement('cite');
      cite.textContent = h.date;
      blockquote.appendChild(p);
      blockquote.appendChild(cite);
      highlightEl.replaceChildren(blockquote);
    }
  }

  loadData();
</script>

<style>
  /* ── Animations ── */

  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Page layout ── */

  .page {
    max-width: 40rem;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md) var(--space-2xl);
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  /* ── Hero ── */

  .hero {
    text-align: center;
    padding: var(--space-2xl) 0 var(--space-lg);
    animation: reveal-up 800ms cubic-bezier(0.25, 0.1, 0.25, 1) both;
  }

  .hero-header {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 700;
    font-variation-settings: 'SOFT' 100, 'wonk' 0;
    font-optical-sizing: auto;
    line-height: var(--leading-tight);
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .hero-sub {
    margin-top: var(--space-sm);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  /* ── Stats — single column ── */

  .stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .stat-card {
    background: var(--color-warm-soft);
    border: 1px solid transparent;
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-soft);
    padding: var(--space-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    box-shadow: 0 0 0 1px var(--color-warm-glow), 0 2px 8px var(--color-warm-glow);
    animation: reveal-up 600ms cubic-bezier(0.25, 0.1, 0.25, 1) both;
  }

  .stat-card:nth-child(1) { animation-delay: 200ms; }
  .stat-card:nth-child(2) { animation-delay: 350ms; }
  .stat-card:nth-child(3) { animation-delay: 500ms; }
  .stat-card:nth-child(4) { animation-delay: 650ms; }

  .stat-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    font-variation-settings: 'SOFT' 100, 'wonk' 0;
    color: var(--color-warm);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* ── Zero-state soft text ── */

  .stat-value--zero {
    font-size: var(--text-base);
    font-weight: 500;
    font-variation-settings: 'SOFT' 100, 'wonk' 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  /* ── Scoreboard — hero treatment ── */

  .stat-card--scoreboard {
    border-left-width: 4px;
    background: var(--color-glow);
    padding: var(--space-xl) var(--space-lg);
  }

  .stat-card--scoreboard .stat-label {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    order: -1;
  }

  .stat-value--score {
    font-size: clamp(2rem, 8vw, 3rem);
    font-weight: 900;
    font-variation-settings: 'SOFT' 50, 'wonk' 0;
    letter-spacing: 0.04em;
  }

  .stat-card--scoreboard .stat-value--zero {
    font-size: var(--text-lg);
  }

  /* ── Streak — split card ── */

  .stat-card--streak {
    gap: var(--space-sm);
  }

  .streak-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
  }

  .streak-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .streak-divider {
    width: 1px;
    height: 2.5rem;
    background: var(--color-border);
  }

  .streak-viz {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    padding-top: var(--space-xs);
    min-height: 1rem;
  }

  :global(.streak-dot) {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.5;
  }

  :global(.streak-dot:last-of-type) {
    opacity: 1;
  }

  :global(.streak-more) {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
    margin-left: 2px;
  }

  /* ── Section heading ── */

  .section-heading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-sm);
  }

  /* ── Journal highlight ── */

  .highlights {
    animation: reveal-up 600ms cubic-bezier(0.25, 0.1, 0.25, 1) 800ms both;
  }

  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-soft);
    overflow: hidden;
  }

  :global(.journal-quote) {
    font-family: var(--font-display);
    font-weight: 400;
    font-variation-settings: 'SOFT' 100, 'wonk' 0;
    font-style: italic;
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    padding: var(--space-lg);
  }

  :global(.journal-quote cite) {
    display: block;
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    font-style: normal;
    color: var(--color-text-muted);
  }

  /* ── Reduced motion ── */

  @media (prefers-reduced-motion: reduce) {
    .hero,
    .stat-card,
    .highlights {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
