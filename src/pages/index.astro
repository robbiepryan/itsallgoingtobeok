---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="It's all going to be ok"
  description="Your wins against ADHD. Evidence of your capability. Powered by LockIn."
>
  <main class="landing">
    <section class="hero">
      <h1 class="hero-title">
        Your wins.<br />
        Your evidence.<br />
        Your proof that ADHD doesn't define you.
      </h1>
      <p class="hero-sub">
        This is the place where your victories live. Every task completed, every
        streak held, every ball you didn't drop — it's all here. Evidence that
        you can, even when ADHD says you can't.
      </p>
    </section>

    <section class="explanation">
      <div class="explanation-card">
        <h2 class="explanation-heading">What is this?</h2>
        <p>
          <strong>itsallgoingtobeok.com</strong> is your evidence board. It connects to
          <a href="#get-app" class="link">LockIn</a>, an Android app built for people
          with ADHD who are tired of dropping balls.
        </p>
        <p>
          Every win you rack up in LockIn shows up here — a living record that
          ADHD is losing ground. Share it with your therapist, your partner, your
          support crew. Or just keep it for yourself, for the days when ADHD tries
          to tell you nothing's working.
        </p>
      </div>
    </section>

    <section class="cta-section">
      <div class="cta-group">
        <a href="/auth/signin" class="cta cta--primary">Sign in</a>
        <a href="#get-app" class="cta cta--secondary" id="get-app">Get the app</a>
      </div>
      <p class="cta-note">
        LockIn is currently in development. Sign up to see your wins when it launches.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .landing {
    max-width: 40rem;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md) var(--space-2xl);
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    justify-content: center;
  }

  /* ── Hero ── */

  .hero {
    text-align: center;
    animation: reveal-up 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) both;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 700;
    font-variation-settings: 'SOFT' 100, 'wonk' 0;
    font-optical-sizing: auto;
    line-height: var(--leading-tight);
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .hero-sub {
    margin-top: var(--space-lg);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 32rem;
    margin-inline: auto;
  }

  /* ── Explanation ── */

  .explanation {
    animation: reveal-up 0.6s cubic-bezier(0.25, 0.1, 0.25, 1) 0.3s both;
  }

  .explanation-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-soft);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .explanation-heading {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    font-variation-settings: 'SOFT' 100, 'wonk' 0;
    color: var(--color-text);
  }

  .explanation-card p {
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .link {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .link:hover {
    opacity: 0.8;
  }

  /* ── CTAs ── */

  .cta-section {
    text-align: center;
    animation: reveal-up 0.6s cubic-bezier(0.25, 0.1, 0.25, 1) 0.5s both;
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  .cta {
    display: inline-block;
    padding: var(--space-sm) var(--space-xl);
    border-radius: var(--radius-soft);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }

  .cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .cta--primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .cta--secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .cta-note {
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* ── Reduced motion ── */

  @media (prefers-reduced-motion: reduce) {
    .hero,
    .explanation,
    .cta-section {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
