---
/**
 * Auth callback — handles Supabase magic link redirect.
 * This page runs as SSR to exchange the auth code for a session,
 * then redirects to the dashboard.
 */
export const prerender = false;

import { createServerClient } from '../../lib/supabase-server';

const { url } = Astro;
const code = url.searchParams.get('code');

if (code) {
  const supabase = createServerClient({ cookies: Astro.cookies, request: Astro.request });
  const { error } = await supabase.auth.exchangeCodeForSession(code);

  if (!error) {
    return Astro.redirect('/dashboard');
  }
}

// If no code or exchange failed, redirect to sign-in
return Astro.redirect('/auth/signin');
---
