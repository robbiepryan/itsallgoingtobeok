---
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "It's all going to be ok",
  description = 'Evidence of your capability. Wins only.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />

    <link
      rel="preload"
      href="/fonts/fraunces-latin-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/atkinson-next-latin-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Page-specific meta tags (e.g., OG tags for profile pages) -->
    <slot name="head" />
  </head>
  <body>
    <!-- Navigation slot — populated by pages that need nav -->
    <slot name="nav" />

    <!-- Main page content -->
    <slot />

    <!-- Site footer with breathing dot + anti-shame tagline -->
    <Footer />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
