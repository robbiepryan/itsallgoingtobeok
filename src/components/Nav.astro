---
/**
 * Nav — minimal navigation bar, adapts based on auth state.
 * Unauthenticated: wordmark + Sign In link
 * Authenticated: wordmark + Dashboard + Sign Out
 *
 * Auth state is resolved client-side via Supabase SDK to keep
 * this component compatible with prerendered (static) pages.
 */
---

<nav class="site-nav" aria-label="Main navigation">
  <a href="/" class="site-nav__wordmark">itsallgoingtobeok</a>

  <!-- Default: show Sign In (replaced client-side if authed) -->
  <div class="site-nav__links" id="nav-links">
    <a href="/auth/signin" class="site-nav__link">Sign in</a>
  </div>
</nav>

<script>
  import { supabase } from '../lib/supabase';

  async function updateNav() {
    const navLinks = document.getElementById('nav-links');
    if (!navLinks) return;

    try {
      const { data: { user } } = await supabase.auth.getUser();
      if (user) {
        navLinks.innerHTML = `
          <a href="/dashboard" class="site-nav__link">Dashboard</a>
          <form method="POST" action="/api/auth/signout" class="site-nav__signout-form">
            <button type="submit" class="site-nav__link site-nav__link--subtle">Sign out</button>
          </form>
        `;
      }
    } catch {
      // Quietly stay in unauthenticated state — no shame, no error
    }
  }

  updateNav();
</script>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-md);
    max-width: 40rem;
    margin: 0 auto;
  }

  .site-nav__wordmark {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    font-variation-settings: 'SOFT' 100, 'wonk' 0;
    color: var(--color-text-muted);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.2s;
  }

  .site-nav__wordmark:hover {
    color: var(--color-text);
  }

  .site-nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .site-nav__link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .site-nav__link:hover {
    opacity: 0.8;
  }

  .site-nav__link--subtle {
    color: var(--color-text-muted);
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    padding: 0;
  }

  .site-nav__signout-form {
    display: inline;
  }
</style>
