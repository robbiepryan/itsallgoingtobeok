---
/**
 * Footer — breathing dot animation + anti-shame tagline.
 * Included in BaseLayout so it appears on every page.
 */
---

<footer class="site-footer">
  <p class="site-footer__text">ADHD is the opponent. Never you.</p>
</footer>

<style>
  @keyframes breathe {
    0%, 100% {
      transform: scale(1);
      opacity: 0.4;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.7;
    }
  }

  .site-footer {
    text-align: center;
    padding: var(--space-lg) 0;
  }

  .site-footer::before {
    content: '';
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    margin: 0 auto var(--space-sm);
    animation: breathe 6s cubic-bezier(0.45, 0, 0.55, 1) infinite;
  }

  .site-footer__text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-footer::before {
      animation: none;
      opacity: 0.5;
    }
  }
</style>
